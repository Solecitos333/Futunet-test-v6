rules_version = '2';

// ═══════════════════════════════════════════════════
// FUTUNET - Firestore Security Rules
// ═══════════════════════════════════════════════════
//
// INSTRUCCIONES: Copia todo este contenido y pégalo en:
// Firebase Console → Firestore Database → Rules
//
// Seguridad implementada:
// ✅ Los usuarios solo pueden leer/escribir sus propios datos
// ✅ Solo admins/superadmins pueden gestionar usuarios y productos
// ✅ Roles verificados server-side (no se pueden auto-escalar)
// ✅ Validación de datos en escritura
// ✅ Inmune a SQL injection (Firestore es NoSQL con consultas tipadas)
// ═══════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function userHasAnyRole(allowedRoles) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.role in allowedRoles ||
             (userData.roles is list && userData.roles.hasAny(allowedRoles));
    }

    function documentHasRole(userData, roleName) {
      return userData.role == roleName ||
             (userData.roles is list && roleName in userData.roles);
    }

    function isSuperAdmin() {
      return isEmailVerified() && userHasAnyRole(['superadmin']);
    }

    function isAdminOrAbove() {
      return isEmailVerified() && userHasAnyRole(['superadmin', 'admin']);
    }

    function isEditorOrAbove() {
      return isEmailVerified() && userHasAnyRole(['superadmin', 'admin', 'editor']);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function canAdminTenant(companyCodes, tenantAdminRole) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isEmailVerified() && (
        documentHasRole(userData, 'superadmin') ||
        (userData.companyCode in companyCodes && (
          documentHasRole(userData, 'admin') ||
          documentHasRole(userData, 'erp_admin') ||
          documentHasRole(userData, tenantAdminRole)
        ))
      );
    }

    function canOperateTenant(companyCodes, tenantAdminRole, tenantOperatorRole, tenantUserRole, tenantUsuarioRole) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isEmailVerified() && (
        documentHasRole(userData, 'superadmin') ||
        (userData.companyCode in companyCodes && (
          documentHasRole(userData, 'admin') ||
          documentHasRole(userData, 'erp_admin') ||
          documentHasRole(userData, 'editor') ||
          documentHasRole(userData, 'erp_operator') ||
          documentHasRole(userData, tenantAdminRole) ||
          documentHasRole(userData, tenantOperatorRole) ||
          documentHasRole(userData, tenantUserRole) ||
          documentHasRole(userData, tenantUsuarioRole)
        ))
      );
    }

    function isCreaticosAdmin() {
      return canAdminTenant(['CREATICOS'], 'creaticos_admin');
    }

    function isCreaticosOperator() {
      return canOperateTenant(['CREATICOS'], 'creaticos_admin', 'creaticos_operator', 'creaticos_user', 'creaticos_usuario');
    }

    function isFutunetAdmin() {
      return canAdminTenant(['FUTUNETSRL', 'FUTUNET'], 'futunetsrl_admin');
    }

    function isFutunetOperator() {
      return canOperateTenant(['FUTUNETSRL', 'FUTUNET'], 'futunetsrl_admin', 'futunetsrl_operator', 'futunetsrl_user', 'futunetsrl_usuario');
    }

    function isPanitasAdmin() {
      return canAdminTenant(['PANITAS'], 'panitas_admin');
    }

    function isPanitasOperator() {
      return canOperateTenant(['PANITAS'], 'panitas_admin', 'panitas_operator', 'panitas_user', 'panitas_usuario');
    }

    function isPanitasKitchen() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isEmailVerified() &&
             userData.companyCode == 'PANITAS' &&
             documentHasRole(userData, 'panitas_kitchen');
    }

    function isAnyTenantAdmin() {
      return isCreaticosAdmin() || isFutunetAdmin() || isPanitasAdmin();
    }

    function isValidBillingInvoice() {
      let data = request.resource.data;
      return data.docType in ['invoice', 'quote', 'proforma'] &&
             data.invoiceNumber is string && data.invoiceNumber.size() > 0 && data.invoiceNumber.size() <= 50 &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 150 &&
             data.clientRnc is string && data.clientRnc.size() <= 30 &&
             data.date is string && data.date.size() == 10 &&
             data.dueDate is string && data.dueDate.size() == 10 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 200 &&
             data.subtotal is number && data.subtotal >= 0 &&
             data.itbis is number && data.itbis >= 0 &&
             data.total is number && data.total > 0 &&
             data.paidAmount is number && data.paidAmount >= 0 && data.paidAmount <= data.total + 0.01 &&
             data.status in ['pending', 'partial', 'unpaid', 'paid', 'cancelled', 'quote', 'proforma', 'converted'] &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.ncf is string && data.ncf.size() <= 19;
    }

    function hasValidNewBillingNcf() {
      let ncf = request.resource.data.ncf;
      return ncf == '' || ncf.matches('^B[0-9]{10}$') || ncf.matches('^E[0-9]{12}$');
    }

    function preservesBillingIdentity() {
      return request.resource.data.invoiceNumber == resource.data.invoiceNumber &&
             request.resource.data.docType == resource.data.docType &&
             request.resource.data.ncf == resource.data.ncf &&
             request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidBillingPayment() {
      let data = request.resource.data;
      return data.invoiceId is string && data.invoiceId.size() > 0 && data.invoiceId.size() <= 150 &&
             data.amount is number && data.amount > 0 &&
             data.method is string && data.method in ['Efectivo', 'Tarjeta', 'Transferencia', 'Cheque'] &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.timestamp == request.time;
    }

    function isValidBillingClient() {
      let data = request.resource.data;
      return data.name is string && data.name.size() > 0 && data.name.size() <= 150 &&
             data.rnc is string && data.rnc.size() <= 30 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.email is string && data.email.size() <= 150 &&
             data.address is string && data.address.size() <= 300;
    }

    function isValidRestaurantOrder(tableId) {
      let data = request.resource.data;
      return data.keys().hasAll([
               'table', 'clientName', 'items', 'notes', 'priority', 'status', 'waiterName',
               'createdBy', 'updatedBy', 'revision', 'cycle', 'createdAt', 'statusChangedAt', 'updatedAt'
             ]) &&
             data.keys().hasOnly([
               'table', 'clientName', 'items', 'notes', 'priority', 'status', 'waiterName',
               'createdBy', 'updatedBy', 'revision', 'cycle', 'createdAt', 'statusChangedAt', 'updatedAt',
               'linkedInvoiceId', 'closedAt', 'closedBy', 'cancellationReason', 'cancelledAt', 'cancelledBy'
             ]) &&
             data.table == tableId && data.table is string && data.table.size() > 0 && data.table.size() <= 50 &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() <= 150 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.notes is string && data.notes.size() <= 500 &&
             data.priority in ['normal', 'high', 'urgent'] &&
             data.status in ['pending', 'preparing', 'ready', 'served', 'pending_payment', 'closed', 'cancelled'] &&
             data.waiterName is string && data.waiterName.size() > 0 && data.waiterName.size() <= 150 &&
             data.createdBy is string && data.createdBy.size() > 0 &&
             data.updatedBy == request.auth.uid &&
             data.revision is int && data.revision > 0 &&
             data.cycle is int && data.cycle > 0 &&
             data.createdAt is timestamp && data.statusChangedAt is timestamp && data.updatedAt == request.time &&
             (data.status != 'closed' || (
               data.linkedInvoiceId is string && data.linkedInvoiceId.size() > 0 &&
               data.closedAt == request.time && data.closedBy == request.auth.uid &&
               existsAfter(/databases/$(database)/documents/panitas_invoices/$(data.linkedInvoiceId))
             )) &&
             (data.status != 'cancelled' || (
               data.cancellationReason is string && data.cancellationReason.size() > 2 && data.cancellationReason.size() <= 500 &&
               data.cancelledAt == request.time && data.cancelledBy == request.auth.uid
             ));
    }

    function isValidRestaurantTransition() {
      let before = resource.data.status;
      let after = request.resource.data.status;
      return before == after ||
             (before == 'pending' && after in ['preparing', 'closed', 'cancelled']) ||
             (before == 'preparing' && after in ['pending', 'ready', 'closed', 'cancelled']) ||
             (before == 'ready' && after in ['pending', 'served', 'closed', 'cancelled']) ||
             (before == 'served' && after in ['pending_payment', 'closed', 'cancelled']) ||
             (before == 'pending_payment' && after in ['closed', 'cancelled']) ||
             (before == 'delivered' && after in ['closed', 'cancelled']) ||
             (before in ['closed', 'cancelled'] && after == 'pending');
    }

    function isValidRestaurantOrderVersion() {
      let data = request.resource.data;
      let isLegacy = !('revision' in resource.data) || !('cycle' in resource.data) || !('createdAt' in resource.data);
      let startsNewCycle = resource.data.status in ['closed', 'cancelled'] && data.status == 'pending';
      return (isLegacy && data.revision == 1 && data.cycle == 1) ||
             (!isLegacy && data.revision == resource.data.revision + 1 && (
               (startsNewCycle && data.cycle == resource.data.cycle + 1 && data.createdAt == request.time && data.createdBy == request.auth.uid) ||
               (!startsNewCycle && data.cycle == resource.data.cycle && data.createdAt == resource.data.createdAt && data.createdBy == resource.data.createdBy)
             ));
    }

    function protectsPreparedRestaurantItems() {
      return request.resource.data.items == resource.data.items ||
             resource.data.status == 'pending' ||
             request.resource.data.status in ['pending', 'closed', 'cancelled'];
    }

    function isValidRestaurantOrderEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['orderId', 'table', 'fromStatus', 'toStatus', 'action', 'revision', 'cycle', 'userId', 'userEmail', 'timestamp']) &&
             data.keys().hasOnly(['orderId', 'table', 'fromStatus', 'toStatus', 'action', 'revision', 'cycle', 'userId', 'userEmail', 'timestamp']) &&
             data.orderId is string && data.orderId.size() > 0 && data.orderId.size() <= 50 &&
             data.table == data.orderId &&
             data.fromStatus is string && data.fromStatus.size() <= 30 &&
             data.toStatus in ['pending', 'preparing', 'ready', 'served', 'pending_payment', 'closed', 'cancelled'] &&
             data.action in ['created', 'items_updated', 'details_updated', 'status_changed', 'cancelled', 'invoiced_and_closed'] &&
             data.revision is int && data.revision > 0 && data.cycle is int && data.cycle > 0 &&
             data.userId == request.auth.uid && data.userEmail is string && data.userEmail.size() <= 150 &&
             data.timestamp == request.time &&
             existsAfter(/databases/$(database)/documents/panitas_table_orders/$(data.orderId)) &&
             getAfter(/databases/$(database)/documents/panitas_table_orders/$(data.orderId)).data.table == data.table &&
             getAfter(/databases/$(database)/documents/panitas_table_orders/$(data.orderId)).data.status == data.toStatus &&
             getAfter(/databases/$(database)/documents/panitas_table_orders/$(data.orderId)).data.revision == data.revision &&
             getAfter(/databases/$(database)/documents/panitas_table_orders/$(data.orderId)).data.cycle == data.cycle;
    }

    // ─── USERS Collection ───
    match /users/{userId} {
      // Logged-in users can read their own data, admins/editors can read all (if email verified)
      allow read: if isEmailVerified() && (isOwner(userId) || isEditorOrAbove());

      // Allow list access only to admins and above (mitigates global users disclosure)
      allow list: if isAdminOrAbove();

      // El registro público solo puede crear usuarios sin privilegios.
      // El primer administrador debe aprovisionarse mediante Firebase Admin o consola segura.
      allow create: if (isSignedIn() && isOwner(userId) &&
        request.resource.data.role == 'user' &&
        request.resource.data.roles is list &&
        request.resource.data.roles.hasOnly(['user'])) || isSuperAdmin();

      // Users can update their own profile (only basic non-sensitive fields and if email verified)
      allow update: if isEmailVerified() && isOwner(userId) && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'roles', 'status', 'companyCode', 'isInternetClient', 'clientCode', 'internetPlan',
          'internetStatus', 'latitude', 'longitude', 'locationNotes', 'locationAccuracy'
        ])) ||
        (resource.data.status == 'pending_verification' &&
         request.resource.data.status == 'active' &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny([
           'role', 'roles', 'companyCode', 'isInternetClient', 'clientCode', 'internetPlan',
           'internetStatus', 'latitude', 'longitude', 'locationNotes', 'locationAccuracy'
         ]))
      );

      // Admins can update any user (change roles, status, etc.)
      // But only superadmin can modify another superadmin
      allow update: if isAdminOrAbove() && (
        !documentHasRole(resource.data, 'superadmin') || isSuperAdmin()
      );

      // Only superadmin can delete users
      allow delete: if isSuperAdmin();
    }

    // ─── PRODUCTS Collection ───
    match /products/{productId} {
      // Anyone can read products (public catalog)
      allow read: if true;

      // Only editors and above can create/update products
      allow create: if isEditorOrAbove() || isFutunetAdmin() || isCreaticosAdmin();
      allow update: if isEditorOrAbove() || isFutunetAdmin() || isCreaticosAdmin() || (
        (isFutunetOperator() || isCreaticosOperator()) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt'])
      );

      // Only admins can delete products
      allow delete: if isAdminOrAbove() || isFutunetAdmin() || isCreaticosAdmin();
    }

    // ─── CARTS Collection ───
    match /carts/{cartId} {
      // Users can read their own carts, admins/editors can read all (if email verified)
      allow read: if isEmailVerified() && (
        cartId == request.auth.uid || isEditorOrAbove()
      );

      // Users can create/update/delete their own carts (if email verified)
      allow create, update, delete: if isEmailVerified() && cartId == request.auth.uid;
    }

    // ─── ORDERS Collection ───
    match /orders/{orderId} {
      // Users can read their own orders, admins/editors can read all (if email verified)
      allow read: if isEmailVerified() && (
        resource.data.userId == request.auth.uid || isEditorOrAbove()
      );

      // Client-side document creation is blocked (orders are created securely via backend API)
      allow create: if false;

      // Only admins/editors can update order status
      allow update: if isEditorOrAbove();

      // Only superadmin can delete orders
      allow delete: if isSuperAdmin();
    }

    // ─── DISCOUNTS Collection ───
    match /discounts/{code} {
      // Anyone signed in with email verified can read discounts (to validate codes)
      allow read: if isEmailVerified();

      // Only admins can manage discounts
      allow create, update, delete: if isAdminOrAbove();
    }

    // ─── CONFIG Collection ───
    match /config/{docId} {
      // Anyone can read config (site settings are public)
      allow read: if true;

      // Only admin or above can change config
      allow write: if isAdminOrAbove();
    }

    // ─── BANNERS Collection ───
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isEditorOrAbove();
    }

    // ─── CATEGORIES Collection ───
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditorOrAbove();
    }

    // ─── BRANDS Collection ───
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isEditorOrAbove();
    }

    // ─── SEARCH QUERIES Collection ───
    match /search_queries/{queryId} {
      // Validate queries limits to protect database from bloat/DoS
      allow create: if isSignedIn() &&
                    request.resource.data.keys().hasOnly(['query', 'timestamp']) &&
                    request.resource.data.query is string &&
                    request.resource.data.query.size() <= 100 &&
                    request.resource.data.timestamp == request.time;
      allow read, delete: if isAdminOrAbove();
    }

    // ─── AUDIT LOGS Collection ───
    match /audit_logs/{logId} {
      // Admins/editors can read and write all logs
      allow read: if isEditorOrAbove();

      // Signed-in users with email verified can create audit logs representing their own actions
      allow create: if isEmailVerified() && (
        isEditorOrAbove() ||
        (isAnyTenantAdmin() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.keys().hasOnly(['action', 'details', 'userId', 'userEmail', 'timestamp']) &&
          request.resource.data.action is string && request.resource.data.action.size() <= 100 &&
          request.resource.data.details is string && request.resource.data.details.size() <= 500 &&
          request.resource.data.timestamp == request.time
        ) || (
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.keys().hasOnly(['action', 'details', 'userId', 'userEmail', 'timestamp']) &&
          request.resource.data.action in ['Inicio de sesión', 'Reporte de pago', 'Pedido por Transferencia'] &&
          request.resource.data.timestamp == request.time
        )
      );
    }

    // ─── SERVICES CONFIG Collection ───
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isEditorOrAbove();
    }

    // ─── COMPETITORS Collection ───
    match /competitors/{competitorId} {
      allow read, write: if isEditorOrAbove();
    }

    // ─── CREATICOS BILLING Collections ───
    match /creaticos_invoices/{invoiceId} {
      allow read: if isCreaticosOperator();
      allow create: if isCreaticosOperator() && isValidBillingInvoice() && hasValidNewBillingNcf();
      allow update: if isValidBillingInvoice() && preservesBillingIdentity() && (
        isCreaticosAdmin() || (isCreaticosOperator() && request.resource.data.status != 'cancelled')
      );
      allow delete: if isCreaticosAdmin();
    }
    match /creaticos_clients/{clientId} {
      allow read: if isCreaticosOperator();
      allow create, update: if isCreaticosOperator() && isValidBillingClient();
      allow delete: if isCreaticosAdmin();
    }
    match /creaticos_payments/{paymentId} {
      allow read: if isCreaticosOperator();
      allow create: if isCreaticosOperator() && isValidBillingPayment();
      allow update, delete: if isCreaticosAdmin();
    }
    match /creaticos_products/{productId} {
      allow read: if isCreaticosOperator();
      allow create, delete: if isCreaticosAdmin();
      allow update: if isCreaticosAdmin() || (
        isCreaticosOperator() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt'])
      );
    }
    match /creaticos_settings/{settingId} {
      allow read: if isCreaticosOperator();
      allow create, delete: if isCreaticosAdmin();
      allow update: if isCreaticosAdmin() || (
        isCreaticosOperator() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nextInvoiceNum', 'nextQuoteNum', 'nextProformaNum',
          'ncfB01Seq', 'ncfB02Seq', 'ncfB12Seq', 'ncfB14Seq', 'ncfB15Seq'
        ])
      );
    }
    match /creaticos_secrets/{secretId} {
      allow read, write: if isCreaticosAdmin();
    }
    match /creaticos_cash_sessions/{sessionId} {
      allow read, create, update: if isCreaticosOperator();
      allow delete: if isCreaticosAdmin();
    }

    // ─── FUTUNET BILLING Collections ───
    match /futunet_invoices/{invoiceId} {
      allow read: if isFutunetOperator();
      allow create: if isFutunetOperator() && isValidBillingInvoice() && hasValidNewBillingNcf();
      allow update: if isValidBillingInvoice() && preservesBillingIdentity() && (
        isFutunetAdmin() || (isFutunetOperator() && request.resource.data.status != 'cancelled')
      );
      allow delete: if isFutunetAdmin();
    }
    match /futunet_clients/{clientId} {
      allow read: if isFutunetOperator();
      allow create, update: if isFutunetOperator() && isValidBillingClient();
      allow delete: if isFutunetAdmin();
    }
    match /futunet_payments/{paymentId} {
      allow read: if isFutunetOperator();
      allow create: if isFutunetOperator() && isValidBillingPayment();
      allow update, delete: if isFutunetAdmin();
    }
    match /futunet_settings/{settingId} {
      allow read: if isFutunetOperator();
      allow create, delete: if isFutunetAdmin();
      allow update: if isFutunetAdmin() || (
        isFutunetOperator() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nextInvoiceNum', 'nextQuoteNum', 'nextProformaNum',
          'ncfB01Seq', 'ncfB02Seq', 'ncfB12Seq', 'ncfB14Seq', 'ncfB15Seq'
        ])
      );
    }
    match /futunet_secrets/{secretId} {
      allow read, write: if isFutunetAdmin();
    }
    match /futunet_cash_sessions/{sessionId} {
      allow read, create, update: if isFutunetOperator();
      allow delete: if isFutunetAdmin();
    }

    // ─── PANITAS BILLING Collections ───
    match /panitas_invoices/{invoiceId} {
      allow read: if isPanitasOperator();
      allow create: if isPanitasOperator() && isValidBillingInvoice() && hasValidNewBillingNcf();
      allow update: if isValidBillingInvoice() && preservesBillingIdentity() && (
        isPanitasAdmin() || (isPanitasOperator() && request.resource.data.status != 'cancelled')
      );
      allow delete: if isPanitasAdmin();
    }
    match /panitas_clients/{clientId} {
      allow read: if isPanitasOperator();
      allow create, update: if isPanitasOperator() && isValidBillingClient();
      allow delete: if isPanitasAdmin();
    }
    match /panitas_payments/{paymentId} {
      allow read: if isPanitasOperator();
      allow create: if isPanitasOperator() && isValidBillingPayment();
      allow update, delete: if isPanitasAdmin();
    }
    match /panitas_products/{productId} {
      allow read: if isPanitasOperator();
      allow create, delete: if isPanitasAdmin();
      allow update: if isPanitasAdmin() || (
        isPanitasOperator() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt'])
      );
    }
    match /panitas_settings/{settingId} {
      allow read: if isPanitasOperator() || isPanitasKitchen();
      allow create, delete: if isPanitasAdmin();
      allow update: if isPanitasAdmin() || (
        isPanitasOperator() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nextInvoiceNum', 'nextQuoteNum', 'nextProformaNum',
          'ncfB01Seq', 'ncfB02Seq', 'ncfB12Seq', 'ncfB14Seq', 'ncfB15Seq'
        ])
      );
    }
    match /panitas_secrets/{secretId} {
      allow read, write: if isPanitasAdmin();
    }
    match /panitas_cash_sessions/{sessionId} {
      allow read, create, update: if isPanitasOperator();
      allow delete: if isPanitasAdmin();
    }
    match /panitas_table_orders/{tableId} {
      allow read: if isPanitasOperator() || isPanitasKitchen();
      allow create: if isPanitasOperator() &&
                       isValidRestaurantOrder(tableId) &&
                       request.resource.data.status == 'pending' &&
                       request.resource.data.createdBy == request.auth.uid &&
                       request.resource.data.revision == 1 &&
                       request.resource.data.cycle == 1 &&
                       request.resource.data.createdAt == request.time &&
                       request.resource.data.statusChangedAt == request.time;
      allow update: if (isPanitasOperator() || (
                         isPanitasKitchen() && (
                           !('revision' in resource.data) ||
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                             'status', 'revision', 'cycle', 'updatedBy', 'statusChangedAt', 'updatedAt'
                           ])
                         )
                       )) &&
                       isValidRestaurantOrder(tableId) &&
                       isValidRestaurantTransition() &&
                       isValidRestaurantOrderVersion() &&
                       protectsPreparedRestaurantItems() &&
                       (!('statusChangedAt' in resource.data) || (
                         request.resource.data.status == resource.data.status
                           ? request.resource.data.statusChangedAt == resource.data.statusChangedAt
                           : request.resource.data.statusChangedAt == request.time
                       ));
      allow delete: if isPanitasAdmin();
    }
    match /panitas_order_events/{eventId} {
      allow read: if isPanitasOperator() || isPanitasKitchen();
      allow create: if (isPanitasOperator() || isPanitasKitchen()) && isValidRestaurantOrderEvent();
      allow update: if false;
      allow delete: if isPanitasAdmin();
    }

    // ─── SERVICE REQUESTS Collection ───
    match /service_requests/{requestId} {
      // Whitelist fields, enforce status 'pending', validate types and limit lengths
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email', 'message', 'serviceId', 'serviceTitle', 'status', 'type', 'createdAt']) &&
                    request.resource.data.keys().hasOnly(['name', 'phone', 'email', 'message', 'serviceId', 'serviceTitle', 'status', 'type', 'createdAt', 'company', 'planRequested', 'profile']) &&
                    request.resource.data.name is string && request.resource.data.name.size() <= 100 &&
                    request.resource.data.phone is string && request.resource.data.phone.size() <= 50 &&
                    request.resource.data.email is string && request.resource.data.email.size() <= 100 &&
                    request.resource.data.message is string && request.resource.data.message.size() <= 1500 &&
                    request.resource.data.serviceId is string && request.resource.data.serviceId.size() <= 50 &&
                    request.resource.data.serviceTitle is string && request.resource.data.serviceTitle.size() <= 100 &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.type in ['standard_service', 'internet_hiring'] &&
                    request.resource.data.createdAt == request.time &&
                    (!('company' in request.resource.data.keys()) || (request.resource.data.company is string && request.resource.data.company.size() <= 100)) &&
                    (!('planRequested' in request.resource.data.keys()) || (request.resource.data.planRequested is string && request.resource.data.planRequested.size() <= 100)) &&
                    (!('profile' in request.resource.data.keys()) || (request.resource.data.profile is string && request.resource.data.profile.size() <= 50));
      allow read, update: if isEditorOrAbove();
      allow delete: if isSuperAdmin();
    }

    // ─── INTERNET PAYMENTS Collection ───
    match /internet_payments/{paymentId} {
      // Validate payment submission fields and enforce status pending (if email verified)
      allow create: if isEmailVerified() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.amount is number &&
                    request.resource.data.amount > 0 &&
                    request.resource.data.timestamp == request.time &&
                    request.resource.data.keys().hasOnly(['userId', 'userName', 'userEmail', 'amount', 'bank', 'voucherUrl', 'storagePath', 'status', 'plan', 'timestamp']) &&
                    request.resource.data.userName is string && request.resource.data.userName.size() <= 100 &&
                    request.resource.data.userEmail is string && request.resource.data.userEmail.size() <= 100 &&
                    request.resource.data.bank is string && request.resource.data.bank.size() <= 50 &&
                    request.resource.data.voucherUrl is string && request.resource.data.voucherUrl.size() <= 500 &&
                    request.resource.data.storagePath is string && request.resource.data.storagePath.size() <= 500 &&
                    request.resource.data.plan is string && request.resource.data.plan.size() <= 50;
      allow read: if isEmailVerified() && (resource.data.userId == request.auth.uid || isEditorOrAbove());
      allow update: if isEditorOrAbove();
      allow delete: if isSuperAdmin();
    }

    // ─── INTERNET TICKETS Collection ───
    match /internet_tickets/{ticketId} {
      // Validate technical support ticket fields and enforce status pending (if email verified)
      allow create: if isEmailVerified() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.timestamp == request.time &&
                    request.resource.data.keys().hasOnly(['userId', 'userName', 'userEmail', 'type', 'details', 'status', 'timestamp', 'requestedPlan']) &&
                    request.resource.data.userName is string && request.resource.data.userName.size() <= 100 &&
                    request.resource.data.userEmail is string && request.resource.data.userEmail.size() <= 100 &&
                    request.resource.data.type is string && request.resource.data.type.size() <= 50 &&
                    request.resource.data.details is string && request.resource.data.details.size() <= 1500 &&
                    (!('requestedPlan' in request.resource.data.keys()) || (request.resource.data.requestedPlan is string && request.resource.data.requestedPlan.size() <= 50));
      allow read: if isEmailVerified() && (resource.data.userId == request.auth.uid || isEditorOrAbove());
      allow update: if isEditorOrAbove();
      allow delete: if isSuperAdmin();
    }

    // ─── DENY EVERYTHING ELSE ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
